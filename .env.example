# Server
PORT=4000
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/zxmoney

# JWT (change this for production)
JWT_SECRET=dev-secret-change-me
JWT_EXPIRES_IN=7d

# Super admin phone (hard-pinned identity)
SUPER_PHONE=9999999999

# Twilio — leave blank in dev to log OTPs to console instead of sending SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Seed demo data on first boot (restaurants, contests, winners, admin users)
SEED_ON_BOOT=true
